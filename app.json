    "experiments": {
      "typedRoutes": true
    },
    "ios": {
      "bundleIdentifier": "com.berlinhomeradar.mobile"
    },
    "android": {
      "package": "com.berlinhomeradar.mobile"
    }
  },
  "version": "2.5.1"
}
