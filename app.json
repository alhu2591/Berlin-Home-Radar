    "name": "Berlin Home Radar",
    "slug": "berlin-home-radar",
    "version": "2.6.1",
    "scheme": "berlinhomeradar",
    "orientation": "portrait",
    "userInterfaceStyle": "automatic",
    "plugins": [
      "expo-router",
      "expo-sqlite",
      "expo-secure-store",
      "expo-notifications"
