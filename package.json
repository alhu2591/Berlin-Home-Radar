{
  "name": "@berlin-home-radar/mobile",
  "version": "2.6.1",
  "private": true,
  "main": "expo-router/entry",
  "scripts": {
    "start": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "typecheck": "tsc --noEmit",
    "typecheck:logic": "tsc -p tsconfig.logic.json --noEmit",
    "worker:typecheck": "npm --prefix workers run typecheck",
    "verify": "npm run typecheck:logic && npm run worker:typecheck"
  },
  "dependencies": {
    "@expo/vector-icons": "^14.1.0",
    "expo": "~54.0.0",
    "expo-notifications": "~0.32.12",
    "expo-router": "~6.0.0",
    "expo-secure-store": "~15.0.7",
    "expo-sqlite": "~16.0.7",
    "expo-status-bar": "~3.0.0",
    "i18next": "^25.0.2",
    "immer": "^10.1.1",
    "react": "19.1.0",
    "react-i18next": "^15.7.3",
    "react-native": "0.81.0",
    "react-native-mmkv": "^3.2.0",
    "react-native-safe-area-context": "~5.6.0",
    "zustand": "^5.0.8",
    "react-dom": "19.1.0",
    "react-native-web": "0.21.0"
  },
  "devDependencies": {
    "@babel/core": "^7.26.0",
    "@types/react": "~19.1.10",
    "babel-plugin-module-resolver": "^5.0.2",
    "typescript": "~5.9.2",
    "babel-preset-expo": "~54.0.6",
    "@types/node": "^22.15.3"
  },
  "engines": {
    "node": ">=20 <23"
  },
  "packageManager": "npm@10.8.2"
}
