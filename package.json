{
  "name": "homesync-berlin",
  "version": "2.0.1",
  "private": true,
  "main": "expo-router/entry",
  "scripts": {
    "start": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "lint": "eslint . --ext .ts,.tsx",
    "format": "prettier --write .",
    "typecheck": "tsc --noEmit",
    "typecheck:logic": "tsc -p tsconfig.logic.json --noEmit",
    "test": "jest",
    "test:ci": "jest --ci --runInBand",
    "worker:typecheck": "npm --prefix workers run typecheck",
    "check": "npm run typecheck:logic && npm run test:ci",
    "verify": "npm run check && npm run worker:typecheck"
  },
  "dependencies": {
    "@expo/vector-icons": "^14.1.0",
    "date-fns": "^4.1.0",
    "expo": "~54.0.0",
    "expo-background-fetch": "~14.0.7",
    "expo-linking": "~8.0.8",
    "expo-localization": "~17.0.7",
    "expo-notifications": "~0.32.12",
    "expo-router": "~6.0.0",
    "expo-secure-store": "~15.0.7",
    "expo-sqlite": "~16.0.7",
    "expo-status-bar": "~3.0.0",
    "expo-task-manager": "~14.0.8",
    "expo-web-browser": "~15.0.7",
    "i18next": "^25.0.2",
    "immer": "^10.1.1",
    "react": "19.1.0",
    "react-i18next": "^15.7.3",
    "react-native": "0.81.0",
    "react-native-mmkv": "^3.2.0",
    "react-native-safe-area-context": "~5.6.0",
    "zustand": "^5.0.8",
    "zod": "^4.1.5"
  },
  "devDependencies": {
    "@babel/core": "^7.26.0",
    "@types/react": "~19.1.10",
    "babel-plugin-module-resolver": "^5.0.2",
    "eslint": "^9.12.0",
    "eslint-config-expo": "~10.0.0",
    "jest": "^29.7.0",
    "jest-expo": "~55.0.13",
    "prettier": "^3.3.3",
    "typescript": "~5.9.2"
  },
  "engines": {
    "node": ">=20 <23"
  }
}
